# =============================================================================
# AutoOps AI — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Full connection string (overrides individual fields below)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autoops

# Individual connection fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autoops
DB_USER=postgres
DB_PASS=postgres

# ─── GEMINI ───────────────────────────────────────────────────────────────────
# Get your key at: AISTUDIO FOR GEMINI
GEMINI_API_KEY=you-api-key
# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail example: use an App Password (not your account password)
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=hello@gmail.com
EMAIL_PASS=your_pass
EMAIL_FROM="AutoOps AI <your-email@gmail.com>"

# ─── Notifications ────────────────────────────────────────────────────────────
# Manager email for escalation alerts
MANAGER_EMAIL=manager@yourcompany.com

# How many hours before deadline to send reminders (default: 24)
REMINDER_HOURS_BEFORE=24

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
